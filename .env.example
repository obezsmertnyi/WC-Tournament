# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# --- Telegram notifications ---
TELEGRAM_BOT_TOKEN=         # from @BotFather
TELEGRAM_CHAT_ID=           # target channel/group id (or @username) for broadcasts

# --- Database ---
DATABASE_URL=postgres://wc:wc@db:5432/wc2026?sslmode=disable

# --- Auth (Google OAuth) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
JWT_SECRET=                 # long random string

# --- App ---
APP_TZ=Europe/Kyiv          # display/lock timezone (storage is UTC)
APP_BASE_URL=http://localhost:8080

# --- AI assistant (optional; OFF unless AI_ENABLED=true) — ADR-0017 ---
# Keyless auth via Workload Identity Federation (no API key). See docs/gemini-wif.md.
# On prod the WIF creds are mounted via docker-compose.gemini.yml; locally use
# `gcloud auth application-default login`.
AI_ENABLED=                 # set to "true" to enable the football AI assistant
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=<GCP_PROJECT>
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/etc/gemini/cred.json   # set on prod (WIF cred-config)
