{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/backend\" && gofmt -w . >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node scripts/gen-traceability.mjs --check >/dev/null 2>&1 || echo '⚠ traceability stale or regressed — run: node scripts/gen-traceability.mjs'"
          }
        ]
      }
    ]
  }
}
