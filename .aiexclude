# Agent context border (machine-enforced token economy).
# Keeps generated, vendored, binary, and secret files out of AI context so the
# model reads signal, not noise. gitignore syntax. Honored by agent tools that
# read .aiexclude (and mirrored by .gitignore for git). See ADR-0013 and the
# "Context border & token economy" note in docs/agentic-engineering.md.

# Secrets — never in context
.env
.env.*

# Vendored / build output
node_modules/
dist/
mcp/dist/
*.tsbuildinfo

# Generated artifacts (regenerated by scripts/CI — not source to reason over)
**/package-lock.json
trace/trace.json
docs/qa/requirements-traceability-matrix.md
quality/trace-baseline.json

# Transient loop state
*.toon

# Binary / diagrams (read the source docs, not the rendered assets)
*.svg
*.png
*.webm
